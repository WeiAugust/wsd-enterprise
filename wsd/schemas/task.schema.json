{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wsd/task",
  "title": "WSD 实现任务",
  "type": "object",
  "required": ["taskId", "type", "title", "estimate", "status"],
  "properties": {
    "taskId": {
      "type": "string",
      "pattern": "^T-\\d{3}$",
      "description": "任务ID，格式：T-NNN",
      "examples": ["T-001", "T-012"]
    },
    "type": {
      "type": "string",
      "enum": ["setup", "data-model", "api", "logic", "ui", "test", "integration", "docs"],
      "description": "任务类型"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 100,
      "description": "任务标题"
    },
    "description": {
      "type": "string",
      "description": "任务详细描述"
    },
    "estimate": {
      "type": "number",
      "minimum": 0.25,
      "maximum": 2,
      "description": "预估工时（小时），最大2小时"
    },
    "actualHours": {
      "type": "number",
      "minimum": 0,
      "description": "实际工时（完成后填写）"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "pattern": "^T-\\d{3}$" },
      "description": "前置任务ID列表",
      "examples": [["T-001", "T-002"]]
    },
    "status": {
      "type": "string",
      "enum": ["TODO", "IN_PROGRESS", "BLOCKED", "DONE", "SKIPPED"],
      "description": "任务状态"
    },
    "doneCriteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "完成标准清单（每项可独立验证）"
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": { "type": "string", "pattern": "^AC-[A-Z0-9]+" },
      "description": "对应的验收条件ID",
      "examples": [["AC-001", "AC-P01"]]
    },
    "commitSha": {
      "type": "string",
      "description": "任务完成对应的最终 commit SHA"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "完成时间"
    },
    "completedBy": {
      "type": "string",
      "description": "完成者（wsd-executor 或人工）"
    }
  },
  "additionalProperties": false
}
